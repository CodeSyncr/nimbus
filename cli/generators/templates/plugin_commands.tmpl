// StatusCommand is an example CLI command for the {{.PascalName}} plugin.
type StatusCommand struct {
	plugin *{{.PascalName}}Plugin
}

func (c *StatusCommand) Name() string        { return "{{.PluginName}}:status" }
func (c *StatusCommand) Description() string { return "Show {{.PascalName}} plugin status" }
func (c *StatusCommand) Run(ctx *cli.Context) error {
	ctx.UI.Successf("%s v%s is running", c.plugin.Name(), c.plugin.Version())
	return nil
}
