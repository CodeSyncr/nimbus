{
  "name": "@nimbus/echo",
  "version": "1.0.0",
  "description": "Real-time client SDK for Nimbus Transmit (SSE channels)",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
