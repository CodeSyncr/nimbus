<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ .title }}</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { sans: ['DM Sans', 'system-ui', 'sans-serif'] }
        }
      }
    }
  </script>
</head>
<body class="min-h-screen bg-slate-950 text-slate-100 font-sans antialiased">
  {{ .embed }}
  <footer class="border-t border-slate-800 py-6 mt-16">
    <div class="max-w-4xl mx-auto px-4 text-center text-slate-500 text-sm">
      <p>Built with <a href="https://github.com/CodeSyncr/nimbus" class="text-amber-400 hover:text-amber-300 transition">Nimbus</a> · AdonisJS-style framework for Go</p>
    </div>
  </footer>
</body>
</html>
